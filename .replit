modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "next dev --turbo -p 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm test"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 3000
externalPort = 6800

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3003

[[ports]]
localPort = 5051
externalPort = 4200

[[ports]]
localPort = 5053
externalPort = 3000

[[ports]]
localPort = 5062
externalPort = 3001

[[ports]]
localPort = 5063
externalPort = 3002

[[ports]]
localPort = 5064
externalPort = 5000

[[ports]]
localPort = 5071
externalPort = 5173

[[ports]]
localPort = 5081
externalPort = 6000

[userenv]

[userenv.shared]

[deployment]
deploymentTarget = "autoscale"
run = ["node_modules/.bin/next", "start", "-p", "5000"]
build = ["pnpm", "build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
